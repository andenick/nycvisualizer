{
  "name": "nycvisualizer-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "NYC Visualizer — React + Vite + Leaflet SPA (Live Bus Map + Sidewalk Explorer). Self-hosted pmtiles basemap, no CDN.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "plotly.js-dist-min": "^3.7.0",
    "protomaps-leaflet": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^4.1.10"
  }
}
