# NYC Granular Mapping Platform (Jane / nycvisualizer) — API credentials TEMPLATE
# Copy to `.env` and fill in your own values. `.env` is gitignored; this file is safe to commit.
# All keys are server-side only — never ship them in client JS.

# MTA BusTime API key. Get one (emailed instantly-to-30min):
#   https://register.developer.obanyc.com/  (name, email, purpose). Rate limit: <=1 req / 30s per key.
MTA_BUSTIME_KEY=

# Socrata app token for the NYC city portal (data.cityofnewyork.us). Create an account:
#   https://data.cityofnewyork.us/signup  (reCAPTCHA v2 + email verification) -> Profile >
#   Developer Settings > Create New App Token. Optional (raises rate limit; bulk exports need none).
SOCRATA_TOKEN_NYC=

# Socrata app token for the NY state / MTA portal (data.ny.gov). Same steps on that portal:
#   https://data.ny.gov/profile/app_tokens
SOCRATA_TOKEN_NY=

# Census API key. Request one (emailed in minutes):
#   https://api.census.gov/data/key_signup.html  (organization + email).
CENSUS_API_KEY=
